<%= for message <- @messages do %>
  <div class={"message #{if message.sender_id == @current_member.id, do: "message-sent", else: "message-received"} mb-2"}>
    <p class="mb-0"><%= message.content %></p>
    <time class="text-muted" style="font-size: 0.75rem;" datetime={DateTime.to_iso8601(message.inserted_at)}>
      <%= Calendar.strftime(message.inserted_at, "%b %d, %H:%M") %>
    </time>
  </div>
<% end %>
