# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=

# GitHub OAuth App credentials
# Create one at https://github.com/settings/developers
# Application name:            ZipLiner          ← shown to users during authorization
# Homepage URL:                http://<PHX_HOST>:<PORT>
# Authorization callback URL:  http://<PHX_HOST>:<PORT>/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Public hostname of the app (no scheme or port)
PHX_HOST=localhost

# Host port to expose (the container always listens on 4000 internally)
PORT=4000
